# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://fnpsnzqedznsgzxjsowe.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_8U2tgV0GuqAo2-SnROncOg_X3DNuk-j
# Optional: Supabase Service Role Key (for server-side operations)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App Configuration
NEXT_PUBLIC_APP_NAME=ICB V2
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# Notifuse lifecycle sync (self-hosted)
# NOTIFUSE_* are consumed by the sync-to-lifecycle Edge Function (set via `supabase secrets set`).
# INTERNAL_LIFECYCLE_SYNC_SECRET is shared between the Next.js app, the Edge Function,
# and the Vault secret `lifecycle_internal_sync_secret`.
NOTIFUSE_API_URL=https://notifuse.indiancoffeebeans.com
NOTIFUSE_API_KEY=
NOTIFUSE_WORKSPACE_ID=
INTERNAL_LIFECYCLE_SYNC_SECRET=

#API v1: HMAC for external_user_id mapping (≥32 characters; e.g. openssl rand -hex 32)
EXTERNAL_ID_HASH_SECRET=

# IndexNow (instant search-engine indexing)
# The key value — must equal the filename and contents of public/<key>.txt
INDEXNOW_API_KEY=
# Shared secret protecting /api/webhooks/indexnow (e.g. openssl rand -hex 32)
# Also stored in Supabase Vault for the MV-refresh pg_net hook
INDEXNOW_WEBHOOK_SECRET=
# Secret for verifying Sanity publish webhook signatures
SANITY_WEBHOOK_SECRET=
